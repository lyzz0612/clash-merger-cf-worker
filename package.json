{
  "name": "clash-merger-cf-worker",
  "version": "1.0.0",
  "description": "Clash 订阅合并工具 - Cloudflare Worker 版本",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev --remote",
    "dev:local": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "keywords": [
    "clash",
    "proxy",
    "cloudflare-worker",
    "subscription"
  ],
  "author": "",
  "license": "MIT",
  "cloudflare": {
    "bindings": {
      "CLASH_KV": {
        "description": "用于存储订阅列表、自定义代理和 Token 的 KV 命名空间，**自动创建**"
      },
      "TOKEN": {
        "description": "访问令牌，用于订阅接口鉴权和管理界面登录，建议使用 `openssl rand -hex 16` 生成"
      }
    }
  },
  "devDependencies": {
    "wrangler": "^4.63.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
